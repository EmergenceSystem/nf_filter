{<<"app">>,<<"kvex">>}.
{<<"build_tools">>,[<<"rebar3">>]}.
{<<"description">>,
 <<"Pure Erlang approximate k-NN vector search backed by sied SIMD">>}.
{<<"files">>,
 [<<"CHANGELOG.md">>,<<"LICENSE">>,<<"README.md">>,<<"rebar.config">>,
  <<"src/kvex.app.src">>,<<"src/kvex.erl">>,<<"src/kvex_app.erl">>,
  <<"src/kvex_sup.erl">>]}.
{<<"licenses">>,[<<"Apache-2.0">>]}.
{<<"links">>,[{<<"GitHub">>,<<"https://github.com/roquess/kvex">>}]}.
{<<"name">>,<<"kvex">>}.
{<<"requirements">>,
 [{<<"sied">>,
   [{<<"app">>,<<"sied">>},
    {<<"optional">>,false},
    {<<"requirement">>,<<"0.2.4">>}]}]}.
{<<"version">>,<<"0.2.1">>}.

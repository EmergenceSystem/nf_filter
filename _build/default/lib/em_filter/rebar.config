{erl_opts, [debug_info]}.

{deps, [
    {gun, "2.1.0"}
]}.

{shell, [
    {config, "config/sys.config"},
    {apps, [em_filter]}
]}.

{profiles, [
    {test, [
        {deps, [
            {cowboy, "2.12.0"}
        ]}
    ]}
]}.

{ct_opts, [
    {sys_config, "config/test.sys.config"}
]}.

{plugins, [
    {rebar3_hex, "7.0.6"}
]}.

{hex, [
    {doc, #{provider => edoc}}
]}.
